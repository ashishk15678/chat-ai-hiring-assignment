# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required)
DATABASE_URL="postgresql://user:password@localhost:5432/llm_logger"

# ── Session ───────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -base64 32
SESSION_SECRET="replace-me-with-a-random-32-char-string-minimum"

# ── GROQ ──────────────────────────────────────────────────────────────────────
# Default server-side Groq API key. Users can override per-request with apiKey body param.
GROQ_API_KEY="gsk_..."

# ── Rate Limiting (Upstash Redis) ─────────────────────────────────────────────
# Optional. If not set, rate limiting is disabled (useful for local dev).
# Create a free Redis database at https://upstash.com/
UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="AXxx..."

# ── Auth ──────────────────────────────────────────────────────────────────────
# Set to "true" to prevent new user registrations (invite-only mode).
# DISABLE_REGISTRATION="false"

# ── Seed ──────────────────────────────────────────────────────────────────────
# Used only by: npm run db:seed
# SEED_ADMIN_EMAIL="admin@example.com"
# SEED_ADMIN_PASSWORD="changeme123"

# ── Next.js ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
